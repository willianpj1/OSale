{
    "name": "root/osale",
    "autoload": {
        "psr-4": {
            "App\\": "App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "Tests/"
        }
    },
    "require": {
        "firebase/php-jwt": "^7.0",
        "league/oauth2-client": "^2.9",
        "league/oauth2-google": "^5.0",
        "php-di/php-di": "^7.1",
        "robmorgan/phinx": "^0.16",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15",
        "slim/twig-view": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "doctrine/migrations": "^3.9",
        "doctrine/dbal": "^4.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.24",
        "laravel/pint": "^1.0"
    },
    "scripts": {
        "test": "pest --testsuite=Architecture --bail",
        "test:cov": "pest --coverage --min=80",
        "test:html": "pest --coverage-html storage/coverage/",
        "analyse": "phpstan analyse",
        "format": "pint",
        "format:check": "pint --test",
        "migrate": "phinx migrate",
        "migrate:rollback": "phinx rollback",
        "migrate:status": "phinx status",
        "migrate:create": "phinx create",
        "ci": [
            "@format:check",
            "@analyse",
            "@test:cov"
        ]
    },
    "config": {
        "process-timeout": 0,
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "apcu-autoloader": true,
        "sort-packages": true,
        "classmap-authoritative": false,
        "prepend-autoloader": false,
        "discard-changes": true,
        "platform": {
            "php": "8.5.4"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}